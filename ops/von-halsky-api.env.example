# Prywatny kontrakt InPost Von Halsky.
# Wartości należy przepisać dokładnie z dokumentacji i danych wydanych
# w Portalu Merchanta. Ten plik jest wyłącznie wzorem — nie wpisuj tu sekretów.
#
# Produkcja odczytuje:
# /srv/artway/ops/secrets/von-halsky.env
# Uprawnienia pliku: właściciel artway, tryb 0600.

INPOST_VON_HALSKY_ENVIRONMENT=production
INPOST_VON_HALSKY_API_BASE_URL=https://UZUPELNIJ-Z-DOKUMENTACJI
INPOST_VON_HALSKY_AUTH_URL=https://UZUPELNIJ-Z-DOKUMENTACJI
INPOST_VON_HALSKY_CLIENT_ID=
INPOST_VON_HALSKY_CLIENT_SECRET=
INPOST_VON_HALSKY_MERCHANT_ID=

# Dozwolone: client_secret_post albo client_secret_basic.
INPOST_VON_HALSKY_AUTH_STYLE=client_secret_post
INPOST_VON_HALSKY_SCOPE=
INPOST_VON_HALSKY_MERCHANT_HEADER=X-Merchant-Id

# Ścieżki i wersja muszą pochodzić z prywatnego kontraktu InPost.
INPOST_VON_HALSKY_HEALTH_PATH=
INPOST_VON_HALSKY_CATALOG_PATH=
INPOST_VON_HALSKY_ORDERS_PATH=
INPOST_VON_HALSKY_CONTRACT_VERSION=

# Opcjonalne do czasu uruchomienia zdarzeń przychodzących.
INPOST_VON_HALSKY_WEBHOOK_SECRET=
