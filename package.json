{
  "name": "artway-tm-sklep",
  "version": "1.0.0",
  "private": true,
  "description": "Sklep Artway-TM — wspólna baza (Netlify Functions + Blobs)",
  "scripts": {
    "build": "node scripts/build-assets.mjs",
    "build:check": "node scripts/build-assets.mjs --check",
    "test": "node --test tests/*.test.mjs",
    "check:legacy": "node scripts/check-artway.mjs",
    "audit:architecture": "node scripts/report-architecture-budgets.mjs",
    "audit:functional": "node scripts/audit-functional-consistency.mjs",
    "benchmark:setup": "sudo -n /bin/bash ops/postgres/setup-isolated-benchmark.sh",
    "benchmark:catalog": "node scripts/run-isolated-catalog-benchmark.mjs --rows=100000",
    "test:storage:isolated": "node scripts/test-dedicated-domain-storage.mjs",
    "server": "node --env-file=.env server.mjs",
    "migrate:netlify": "node scripts/migrate-netlify-to-postgres.mjs",
    "migrate:domain": "node scripts/migrate-normalized-domain-storage.mjs",
    "verify:domain-tables": "node scripts/verify-dedicated-domain-storage.mjs",
    "verify": "npm run build:check && npm run check:legacy && npm run audit:functional && npm test",
    "check": "npm run verify"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@zxing/browser": "^0.2.0",
    "jsqr": "^1.4.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "qrcode-generator": "^1.4.4"
  },
  "overrides": {
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0"
  }
}
